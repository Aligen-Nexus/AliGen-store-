<section class="collections-showcase">

  <div class="section-header">
    <span>🛍️ تصفح الأقسام</span>
    <h2>تسوق حسب الفئة</h2>
    <p>
      اختر الفئة التي تناسبك واستكشف أفضل المنتجات
    </p>
  </div>

  <div class="collections-grid">

    {% for collection in collections %}
      {% if collection.products_count > 0 %}

      <a href="{{ collection.url }}" class="collection-card">

        {% if collection.featured_image %}
          <img
            src="{{ collection.featured_image | image_url: width: 800 }}"
            alt="{{ collection.title }}"
          >
        {% endif %}

        <div class="collection-overlay">
          <h3>{{ collection.title }}</h3>
          <span>
            {{ collection.products_count }} منتج
          </span>
        </div>

      </a>

      {% endif %}
    {% endfor %}

  </div>

</section>

{% schema %}
{
  "name": "Collections Showcase",
  "settings": [],
  "presets": [
    {
      "name": "Collections Showcase"
    }
  ]
}
{% endschema %}
