<section class="special-offer">

  <div class="offer-content">

    <span class="offer-badge">
      🔥 عرض حصري لفترة محدودة
    </span>

    <h2>
      خصومات تصل إلى <span>50%</span>
    </h2>

    <p>
      لا تفوت الفرصة، استمتع بأفضل العروض على منتجات AliGen Store
    </p>

    <div class="countdown">

      <div class="time-box">
        <span id="days">00</span>
        <small>يوم</small>
      </div>

      <div class="time-box">
        <span id="hours">00</span>
        <small>ساعة</small>
      </div>

      <div class="time-box">
        <span id="minutes">00</span>
        <small>دقيقة</small>
      </div>

      <div class="time-box">
        <span id="seconds">00</span>
        <small>ثانية</small>
      </div>

    </div>

    <a href="/collections/all" class="offer-btn">
      تسوق الآن
    </a>

  </div>

</section>

{% schema %}
{
  "name": "Special Offer Banner",
  "settings": [],
  "presets": [
    {
      "name": "Special Offer Banner"
    }
  ]
}
{% endschema %}
